    if buffers.get("buffer0002") != "beta":
        raise SystemExit(f"u should restore deleted buffer, got {buffers!r}")
    if displayed_buffers(app) != initial_order:
        raise SystemExit(f"u should restore buffer order before delete, got {displayed_buffers(app)!r}")
    app.handle_normal_key(18)
    if "buffer0002" in buffers:
        raise SystemExit(f"C-r should redo buffer delete, got {buffers!r}")
    if displayed_buffers(app) != after_delete_order:
        raise SystemExit(f"C-r should restore buffer order after delete, got {displayed_buffers(app)!r}")

    buffers["buffer0002"] = "beta"
    if "buffer0002" in buffer_order:
        buffer_order.remove("buffer0002")
    buffer_order.insert(1, "buffer0002")
    app.load_rows()
    before_edit_order = displayed_buffers(app)
    app.selected = 2
    app.handle_normal_key(ord("e"))
    after_edit_order = displayed_buffers(app)
    if buffers.get("buffer0001") != "edited buffer":
        raise SystemExit(f"e should edit selected buffer, got {buffers!r}")
    if after_edit_order != ["buffer0001", "buffer0003", "buffer0002"]:
