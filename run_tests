  PATH="$tmpdir:$PATH" TMUX_BCB_SOCKET=fake TMUX_BCB_FAKE_TMUX_LOG="$log" "$ROOT_DIR/scripts/tmux-better-copy-buffer.sh" paste-touch buffer0001 %1

  assert_has_line "$(cat "$log")" "paste-buffer -t %1 -b buffer0001" "paste-touch targets the invoking pane"
  if awk '
    /paste-buffer -t %1 -b buffer0001/ { paste = NR }
    /save-buffer -b buffer0001/ { save = NR }
    END { exit paste && save && paste < save ? 0 : 1 }
  ' "$log"; then
    :
  else
    printf 'not ok - paste-touch pastes before recency refresh\nlog:\n%s\n' "$(cat "$log")" >&2
    exit 1
  fi

  rm -rf "$tmpdir"
  trap - EXIT HUP INT TERM
  echo "ok - paste-touch uses target pane when provided"
}

test_paste_text_file_pastes_arbitrary_text() {
  sock=$(start_tmux)
  tmpdir=$(mktemp -d "${TMPDIR:-/tmp}/tmux-bcb-pin-paste.XXXXXX")
  trap 'rm -rf "$tmpdir"; stop_tmux "$sock"' EXIT HUP INT TERM

  payload=$(printf 'pinned line one\nsecond line with "quotes" and $dollar')
  printf '%s' "$payload" >"$tmpdir/pin.txt"
  target_pane=$(tmux_test "$sock" display-message -p '#{pane_id}')

  TMUX_BCB_SOCKET=$sock "$ROOT_DIR/scripts/tmux-better-copy-buffer.sh" paste-text-file "$tmpdir/pin.txt" "$target_pane"

  pane=$(capture_pane_text "$sock")
  assert_contains "$pane" "pinned line one" "paste-text-file pastes the first line"
  assert_contains "$pane" 'second line with "quotes" and $dollar' "paste-text-file pastes shell-sensitive text"

  buffers=$(tmux_test "$sock" list-buffers -F '#{buffer_name}')
  assert_not_contains "$buffers" "tmux-bcb-pin" "paste-text-file deletes its temporary buffer"

  top_buffer=$(tmux_test "$sock" list-buffers -F '#{buffer_name}' -f '#{m/r:^buffer[0-9]+$,#{buffer_name}}' 2>/dev/null | sed -n '1p' || true)
  if [ -z "$top_buffer" ]; then
    fail "paste-text-file inserts pin text into a normal auto buffer"
  fi
  top_content=$(tmux_test "$sock" show-buffer -b "$top_buffer")
  assert_eq "$payload" "$top_content" "paste-text-file inserts pin text into a normal auto buffer"

  stop_tmux "$sock"
  rm -rf "$tmpdir"
  trap - EXIT HUP INT TERM
  echo "ok - paste-text-file pastes arbitrary text"
}

