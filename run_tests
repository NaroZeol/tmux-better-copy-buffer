  assert_contains "$buffers" "buffer0002" "pin paste keeps other auto buffers in place"
  assert_not_contains "$buffers" "tmux-bcb-pin" "temporary pin buffer is deleted after paste"

  stop_tmux "$sock"
  rm -rf "$tmpdir"
  trap - EXIT HUP INT TERM
  echo "ok - paste-text-file adds auto buffer without deduplicating existing"
}

