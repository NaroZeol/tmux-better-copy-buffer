        buffers[args[1]] = "edited buffer"
        move_buffer_to_front(args[1])
        return SimpleNamespace(returncode=0, stdout="", stderr="")
    if args[:1] == ["set-buffer-file"]:
        with open(args[2], "r", encoding="utf-8") as handle:
            buffers[args[1]] = handle.read()
        move_buffer_to_front(args[1])
        return SimpleNamespace(returncode=0, stdout="", stderr="")
    raise SystemExit(f"unexpected script call: {args!r}")


module.run_script = fake_run_script

with tempfile.TemporaryDirectory() as tmpdir:
    db_path = os.path.join(tmpdir, "pins.sqlite3")
    app = module.App(FakeScreen(), "script", "%1", "on", db_path)
    app.load_rows()
    initial_order = displayed_buffers(app)
    if initial_order != ["buffer0003", "buffer0002", "buffer0001"]:
        raise SystemExit(f"initial order should follow tmux recency, got {initial_order!r}")

    app.selected = 1
    app.handle_normal_key(ord("d"))
    after_delete_order = displayed_buffers(app)
    if after_delete_order != ["buffer0003", "buffer0001"]:
        raise SystemExit(f"d should keep remaining buffer order, got {after_delete_order!r}")
    if "buffer0002" in buffers:
