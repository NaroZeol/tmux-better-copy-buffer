tmux_socket_dir() {
  if [ -d /private/tmp ] && [ -w /private/tmp ]; then
    printf '%s\n' /private/tmp
  else
    printf '%s\n' "${TMPDIR:-/tmp}"
  fi
}

new_tmux_socket() {
  mktemp -u "$(tmux_socket_dir)/tmux-bcb-test.XXXXXX"
}

start_tmux() {
  sock=$(new_tmux_socket)
  TMUX_BCB_SOCKET=$sock tmux_bcb_tmux -f /dev/null new-session -d -x 80 -y 24 -s bcb-test
  printf '%s\n' "$sock"
}

tmux_test() {
  sock=$1
  shift
  TMUX_BCB_SOCKET=$sock tmux_bcb_tmux "$@"
}

stop_tmux() {
  sock=$1
  tmux_test "$sock" kill-server >/dev/null 2>&1 || true
}

top_buffer_name() {
  sock=$1
  tmux_test "$sock" list-buffers -F '#{buffer_name}' | sed -n '1p'
}

capture_pane_text() {
  sock=$1
  tmux_test "$sock" capture-pane -p -J | tr -d '\r'
}

start_attached_client() {
  sock=$1
  log=${TMPDIR:-/tmp}/tmux-bcb-client.$$.log
  if script -q -c true /dev/null >/dev/null 2>&1; then
    sleep 1000 | script -q -c "TERM=xterm-256color tmux -f /dev/null -S $sock new-session -x 80 -y 24 -s bcb-test" "$log" >/dev/null 2>&1 &
  else
    sleep 1000 | script -q "$log" env TERM=xterm-256color tmux -f /dev/null -S "$sock" new-session -x 80 -y 24 -s bcb-test >/dev/null 2>&1 &
  fi
  printf '%s\n' "$!"
}

wait_for_client() {
  sock=$1
  i=0
  while [ "$i" -lt 50 ]; do
    client=$(tmux_test "$sock" list-clients -F '#{client_name}' 2>/dev/null | sed -n '1p')
    if [ "$client" ]; then
      printf '%s\n' "$client"
      return 0
    fi
    i=$((i + 1))
    sleep 0.1
  done
  fail "attached tmux client appears"
}

