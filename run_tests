#!/usr/bin/env sh
set -eu

ROOT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
. "$ROOT_DIR/scripts/lib/tmux.sh"

if ! command -v tmux >/dev/null 2>&1; then
  echo "not ok - tmux is required" >&2
  exit 1
fi

if ! command -v script >/dev/null 2>&1; then
  echo "not ok - script is required" >&2
  exit 1
fi

fail() {
  echo "not ok - $1" >&2
  exit 1
}

assert_eq() {
  expected=$1
  actual=$2
  message=$3

  if [ "$expected" != "$actual" ]; then
    printf 'not ok - %s\nexpected: %s\nactual:   %s\n' "$message" "$expected" "$actual" >&2
    exit 1
  fi
}

assert_contains() {
  haystack=$1
  needle=$2
  message=$3

  case "$haystack" in
    *"$needle"*) ;;
    *) printf 'not ok - %s\nmissing: %s\nin:      %s\n' "$message" "$needle" "$haystack" >&2; exit 1 ;;
  esac
}

assert_not_contains() {
  haystack=$1
  needle=$2
  message=$3

  case "$haystack" in
    *"$needle"*) printf 'not ok - %s\nunexpected: %s\nin:         %s\n' "$message" "$needle" "$haystack" >&2; exit 1 ;;
    *) ;;
  esac
}

assert_has_line() {
  haystack=$1
  expected=$2
  message=$3

  if printf '%s\n' "$haystack" | awk -v expected="$expected" '$0 == expected { found = 1 } END { exit found ? 0 : 1 }'; then
    :
  else
    printf 'not ok - %s\nmissing line: %s\nin:           %s\n' "$message" "$expected" "$haystack" >&2
    exit 1
  fi
}

make_target_pane_fake_tmux() {
  dir=$1
  log=$2

  cat >"$dir/tmux" <<'SH'
#!/usr/bin/env sh
if [ "${1:-}" = "-S" ]; then
  shift 2
fi

printf '%s\n' "$*" >> "$TMUX_BCB_FAKE_TMUX_LOG"

case ${1:-} in
  show-option)
    case ${3:-} in
      @better-copy-buffer-ui) printf '%s\n' "tui" ;;
      @better-copy-buffer-tui-preview) printf '%s\n' "on" ;;
      @better-copy-buffer-tui-layout) ;;
      @better-copy-buffer-pins-db) printf '%s\n' "/tmp/tmux-bcb-pins.sqlite3" ;;
      @better-copy-buffer-display-messages) printf '%s\n' "on" ;;
      status-style) printf '%s\n' "fg=colour7,bg=colour2" ;;
      *) ;;
    esac
    ;;
  bind-key | set-option)
    ;;
  list-buffers)
    printf '%s\n' "100	buffer0001	alpha"
    ;;
  save-buffer)
    file=
    for arg do
      file=$arg
    done
    printf '%s\n' "alpha" >"$file"
    ;;
  paste-buffer | load-buffer | delete-buffer | choose-buffer | display-message)
    ;;
  *)
    printf '%s\n' "unexpected tmux command: $*" >&2
    exit 64
    ;;
esac
SH
  chmod +x "$dir/tmux"
  : >"$log"
}

make_fake_tui() {
  dir=$1
cat > "$dir/tui" <<'SH'
#!/usr/bin/env sh
: > "$TMUX_BCB_FAKE_TUI_ARGS"
for arg do
  printf '%s\n' "$arg" >> "$TMUX_BCB_FAKE_TUI_ARGS"
done
if [ "${TMUX_BCB_FAKE_TUI_STATUS_STYLE:-}" ]; then
  printf '%s\n' "${TMUX_BCB_STATUS_STYLE:-}" > "$TMUX_BCB_FAKE_TUI_STATUS_STYLE"
fi
SH
  chmod +x "$dir/tui"
}

test_tui_popup_binding_passes_current_pane_to_choose_tui() {
  tmpdir=$(mktemp -d "${TMPDIR:-/tmp}/tmux-bcb-target-pane.XXXXXX")
  trap 'rm -rf "$tmpdir"' EXIT HUP INT TERM

  log="$tmpdir/tmux.log"
  make_target_pane_fake_tmux "$tmpdir" "$log"

  PATH="$tmpdir:$PATH" TMUX_BCB_SOCKET=fake TMUX_BCB_FAKE_TMUX_LOG="$log" "$ROOT_DIR/tmux-better-copy-buffer.tmux"

  output=$(cat "$log")
  assert_contains "$output" "bind-key = run-shell -b -C display-popup" "TUI binding expands pane format before opening popup"
  assert_contains "$output" "-e TMUX_BCB_TARGET=#{pane_id}" "TUI binding passes invoking pane id through popup environment"
  assert_contains "$output" "-e TMUX_BCB_STATUS_STYLE=#{status-style}" "TUI binding passes status style through popup environment"
  assert_contains "$output" "-e TMUX_BCB_TUI_LAYOUT=#{@better-copy-buffer-tui-layout}" "TUI binding passes persisted layout through popup environment"
  assert_contains "$output" "scripts/tui.py" "TUI binding starts the Python TUI directly"
  assert_contains "$output" "25l" "TUI binding hides the cursor before Python starts"
  assert_contains "$output" "trap" "TUI binding registers cursor restore on popup exit"
  assert_contains "$output" "25h" "TUI binding restores the cursor when popup exits"
  assert_not_contains "$output" "choose-tui" "TUI binding avoids the choose-tui wrapper on startup"

  rm -rf "$tmpdir"
  trap - EXIT HUP INT TERM
  echo "ok - TUI popup binding starts fast path with current pane"
}

test_paste_touch_uses_target_pane_when_provided() {
  tmpdir=$(mktemp -d "${TMPDIR:-/tmp}/tmux-bcb-target-pane.XXXXXX")
  trap 'rm -rf "$tmpdir"' EXIT HUP INT TERM

  log="$tmpdir/tmux.log"
