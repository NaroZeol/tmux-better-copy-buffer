test_binding_options_are_respected() {
  sock=$(start_tmux)
  trap 'stop_tmux "$sock"' EXIT HUP INT TERM

  tmux_test "$sock" set-option -g @better-copy-buffer-bind-keys off
  TMUX_BCB_SOCKET=$sock "$ROOT_DIR/tmux-better-copy-buffer.tmux"
  default_choose=$(tmux_test "$sock" list-keys -T prefix =)
  default_paste=$(tmux_test "$sock" list-keys -T prefix ']')
  assert_not_contains "$default_choose" "tmux-better-copy-buffer.sh" "bind-keys off leaves prefix = unchanged"
  assert_not_contains "$default_paste" "tmux-better-copy-buffer.sh" "bind-keys off leaves prefix ] unchanged"

  tmux_test "$sock" set-option -g @better-copy-buffer-bind-keys on
  tmux_test "$sock" set-option -g @better-copy-buffer-choose-key B
  tmux_test "$sock" set-option -g @better-copy-buffer-paste-key P
  TMUX_BCB_SOCKET=$sock "$ROOT_DIR/tmux-better-copy-buffer.tmux"

  custom_choose=$(tmux_test "$sock" list-keys -T prefix B)
  custom_paste=$(tmux_test "$sock" list-keys -T prefix P)
  assert_contains "$custom_choose" "tmux-better-copy-buffer.sh choose" "custom choose key is bound"
  assert_contains "$custom_paste" "tmux-better-copy-buffer.sh paste-latest" "custom paste key is bound"

  stop_tmux "$sock"
  trap - EXIT HUP INT TERM
  echo "ok - binding options are respected"
}

test_reverse_sort_option_is_respected() {
  sock=$(mktemp -u "/tmp/tmux-bcb-test.XXXXXX")
  client_pid=$(start_attached_client "$sock")
  trap 'stop_tmux "$sock"; wait "$client_pid" >/dev/null 2>&1 || true' EXIT HUP INT TERM

  client=$(wait_for_client "$sock")
  tmux_test "$sock" set-option -g @better-copy-buffer-reverse-sort on
  TMUX_BCB_SOCKET=$sock "$ROOT_DIR/tmux-better-copy-buffer.tmux"

  tmux_test "$sock" set-buffer -b buffer0001 'alpha'
  tmux_test "$sock" set-buffer -b buffer0002 'beta'

  tmux_test "$sock" switch-client -c "$client" -T prefix
  tmux_test "$sock" send-keys -c "$client" -K =
  sleep 0.5

  messages=$(tmux_test "$sock" show-messages)
  assert_contains "$messages" "choose-buffer -r -O time" "reverse sort option passes -r to native chooser"

  tmux_test "$sock" send-keys q >/dev/null 2>&1 || true
  stop_tmux "$sock"
  wait "$client_pid" >/dev/null 2>&1 || true
  trap - EXIT HUP INT TERM
  echo "ok - reverse sort option is respected"
}

test_non_auto_buffer_names_are_rejected() {
  sock=$(start_tmux)
  trap 'stop_tmux "$sock"' EXIT HUP INT TERM

  tmux_test "$sock" set-buffer -b buffer123x 'not-auto'
  if TMUX_BCB_SOCKET=$sock "$ROOT_DIR/scripts/tmux-better-copy-buffer.sh" paste-touch buffer123x; then
    fail "non-auto buffer name is rejected"
  fi

  pane=$(capture_pane_text "$sock")
  printf '%s\n' "$pane" | grep -F 'not-auto' >/dev/null && fail "rejected buffer was not pasted"

  stop_tmux "$sock"
  trap - EXIT HUP INT TERM
  echo "ok - non-auto buffer names are rejected"
}

test_default_display_message_on_binding_failure() {
  sock=$(mktemp -u "/tmp/tmux-bcb-test.XXXXXX")
  client_pid=$(start_attached_client "$sock")
  trap 'stop_tmux "$sock"; wait "$client_pid" >/dev/null 2>&1 || true' EXIT HUP INT TERM

  client=$(wait_for_client "$sock")
  TMUX_BCB_SOCKET=$sock "$ROOT_DIR/tmux-better-copy-buffer.tmux"

  tmux_test "$sock" switch-client -c "$client" -T prefix
  tmux_test "$sock" send-keys -c "$client" -K ']'
  sleep 0.5

  messages=$(tmux_test "$sock" show-messages 2>/dev/null || true)
  assert_contains "$messages" "tmux-better-copy-buffer: no buffers" "default display messages show binding failure text"

  stop_tmux "$sock"
  wait "$client_pid" >/dev/null 2>&1 || true
  trap - EXIT HUP INT TERM
  echo "ok - default display message appears on binding failure"
}

test_display_messages_can_be_disabled() {
  sock=$(start_tmux)
  trap 'stop_tmux "$sock"' EXIT HUP INT TERM

  tmux_test "$sock" set-option -g @better-copy-buffer-display-messages off
  tmux_test "$sock" set-buffer -b buffer123x 'not-auto'

  if TMUX_BCB_SOCKET=$sock "$ROOT_DIR/scripts/tmux-better-copy-buffer.sh" paste-touch buffer123x; then
    fail "non-auto buffer name is still rejected when messages are disabled"
  fi

  messages=$(tmux_test "$sock" show-messages 2>/dev/null || true)
  assert_not_contains "$messages" "unsupported buffer name" "disabled display messages suppress plugin failure text"

  stop_tmux "$sock"
  trap - EXIT HUP INT TERM
  echo "ok - display messages can be disabled"
}

test_paste_latest_without_buffers_fails_cleanly() {
  sock=$(start_tmux)
  trap 'stop_tmux "$sock"' EXIT HUP INT TERM

  if TMUX_BCB_SOCKET=$sock "$ROOT_DIR/scripts/tmux-better-copy-buffer.sh" paste-latest; then
    fail "paste-latest fails when no buffers exist"
  fi

  pane=$(capture_pane_text "$sock")
  assert_not_contains "$pane" "tmux-better-copy-buffer" "no-buffer failure does not write command noise into pane"

  stop_tmux "$sock"
  trap - EXIT HUP INT TERM
  echo "ok - paste-latest without buffers fails cleanly"
}

