test_binding_options_are_respected() {
  sock=$(start_tmux)
  trap 'stop_tmux "$sock"' EXIT HUP INT TERM

  tmux_test "$sock" set-option -g @better-copy-buffer-bind-keys off
  TMUX_BCB_SOCKET=$sock "$ROOT_DIR/tmux-better-copy-buffer.tmux"
  default_choose=$(tmux_test "$sock" list-keys -T prefix =)
  default_paste=$(tmux_test "$sock" list-keys -T prefix ']')
  assert_not_contains "$default_choose" "tmux-better-copy-buffer.sh" "bind-keys off leaves prefix = unchanged"
  assert_not_contains "$default_paste" "tmux-better-copy-buffer.sh" "bind-keys off leaves prefix ] unchanged"

  tmux_test "$sock" set-option -g @better-copy-buffer-bind-keys on
  tmux_test "$sock" set-option -g @better-copy-buffer-ui tui
  tmux_test "$sock" set-option -g @better-copy-buffer-popup-width 95%
  tmux_test "$sock" set-option -g @better-copy-buffer-popup-height 90%
  tmux_test "$sock" set-option -g @better-copy-buffer-choose-key F
  TMUX_BCB_SOCKET=$sock "$ROOT_DIR/tmux-better-copy-buffer.tmux"

  tui_choose=$(tmux_test "$sock" list-keys -T prefix F)
  assert_contains "$tui_choose" "display-popup" "TUI choose key opens a popup"
  assert_contains "$tui_choose" "-w 95%" "TUI choose key uses configured popup width"
  assert_contains "$tui_choose" "-h 90%" "TUI choose key uses configured popup height"
  assert_not_contains "$tui_choose" "-S" "TUI choose key leaves popup border style to tmux defaults"
  assert_contains "$tui_choose" "TMUX_BCB_STATUS_STYLE=#{status-style}" "TUI choose key passes status style to the TUI"
  assert_not_contains "$tui_choose" "-S #{status-style}" "TUI popup border style does not inherit status-style"
  assert_contains "$tui_choose" "TMUX_BCB_TARGET=#{pane_id}" "TUI choose key passes target pane through popup environment"
  assert_contains "$tui_choose" "scripts/tui.py" "TUI choose key starts the Python TUI directly"
  assert_not_contains "$tui_choose" "choose-tui" "TUI choose key avoids the choose-tui wrapper on startup"

  tmux_test "$sock" set-option -g @better-copy-buffer-popup-border-style 'fg=colour39,bg=default'
  tmux_test "$sock" set-option -g @better-copy-buffer-choose-key G
  TMUX_BCB_SOCKET=$sock "$ROOT_DIR/tmux-better-copy-buffer.tmux"

  styled_tui_choose=$(tmux_test "$sock" list-keys -T prefix G)
  assert_not_contains "$styled_tui_choose" "fg=colour39,bg=default" "removed popup border style option is ignored"

  tmux_test "$sock" set-option -g @better-copy-buffer-ui native
  tmux_test "$sock" set-option -g @better-copy-buffer-choose-key N
  TMUX_BCB_SOCKET=$sock "$ROOT_DIR/tmux-better-copy-buffer.tmux"

  native_choose=$(tmux_test "$sock" list-keys -T prefix N)
  assert_contains "$native_choose" "choose-buffer" "native UI choose key opens tmux choose-buffer"
  assert_not_contains "$native_choose" "display-popup" "native UI choose key does not open a popup"

  tmux_test "$sock" set-option -g @better-copy-buffer-choose-key B
  tmux_test "$sock" set-option -g @better-copy-buffer-paste-key P
  TMUX_BCB_SOCKET=$sock "$ROOT_DIR/tmux-better-copy-buffer.tmux"

  custom_choose=$(tmux_test "$sock" list-keys -T prefix B)
  custom_paste=$(tmux_test "$sock" list-keys -T prefix P)
  assert_contains "$custom_choose" "choose-buffer" "custom choose key opens native chooser directly"
  assert_contains "$custom_choose" "-O time" "custom choose key sorts native chooser by time"
  assert_contains "$custom_choose" "-F \"#{buffer_sample}\"" "custom choose key shows buffer samples by default"
  assert_not_contains "$custom_choose" "choose-buffer -Z" "custom choose key does not zoom by default"
  assert_not_contains "$custom_choose" "choose-buffer -N" "custom choose key keeps native preview visible by default"
  assert_contains "$custom_choose" "run-shell" "custom choose key runs paste-touch after selection"
  assert_contains "$custom_choose" "tmux-better-copy-buffer.sh paste-touch" "custom choose key still refreshes pasted buffers"
  assert_not_contains "$custom_choose" "run-shell -b" "custom choose key waits for paste before returning to pane"
  assert_not_contains "$custom_choose" "tmux-better-copy-buffer.sh choose" "custom choose key avoids shell wrapper on open"
  assert_contains "$custom_paste" "tmux-better-copy-buffer.sh paste-latest" "custom paste key is bound"

  tmux_test "$sock" set-option -g @better-copy-buffer-preview off
  tmux_test "$sock" set-option -g @better-copy-buffer-choose-key C
  TMUX_BCB_SOCKET=$sock "$ROOT_DIR/tmux-better-copy-buffer.tmux"

  preview_choose=$(tmux_test "$sock" list-keys -T prefix C)
  assert_contains "$preview_choose" "choose-buffer -N" "preview option can disable initial preview"

  tmux_test "$sock" set-option -g @better-copy-buffer-preview on
  tmux_test "$sock" set-option -g @better-copy-buffer-zoom on
  tmux_test "$sock" set-option -g @better-copy-buffer-choose-key Z
  TMUX_BCB_SOCKET=$sock "$ROOT_DIR/tmux-better-copy-buffer.tmux"

  zoom_choose=$(tmux_test "$sock" list-keys -T prefix Z)
  assert_contains "$zoom_choose" "choose-buffer -Z" "zoom option can open chooser in a zoomed pane"

  tmux_test "$sock" set-option -g @better-copy-buffer-list-format '#{buffer_name} #{buffer_size} bytes'
  tmux_test "$sock" set-option -g @better-copy-buffer-choose-key L
  TMUX_BCB_SOCKET=$sock "$ROOT_DIR/tmux-better-copy-buffer.tmux"

  list_format_choose=$(tmux_test "$sock" list-keys -T prefix L)
  assert_contains "$list_format_choose" "-F \"#{buffer_name} #{buffer_size} bytes\"" "list format option can use lightweight rows"

  stop_tmux "$sock"
  trap - EXIT HUP INT TERM
  echo "ok - binding options are respected"
}

test_reverse_sort_option_is_respected() {
  sock=$(new_tmux_socket)
  client_pid=$(start_attached_client "$sock")
  trap 'stop_tmux "$sock"; wait "$client_pid" >/dev/null 2>&1 || true' EXIT HUP INT TERM

  client=$(wait_for_client "$sock")
  tmux_test "$sock" set-option -g @better-copy-buffer-ui native
  tmux_test "$sock" set-option -g @better-copy-buffer-reverse-sort on
  TMUX_BCB_SOCKET=$sock "$ROOT_DIR/tmux-better-copy-buffer.tmux"

  tmux_test "$sock" set-buffer -b buffer0001 'alpha'
  tmux_test "$sock" set-buffer -b buffer0002 'beta'

  tmux_test "$sock" switch-client -c "$client" -T prefix
  tmux_test "$sock" send-keys -c "$client" -K =
  sleep 0.5

  messages=$(tmux_test "$sock" show-messages)
  assert_contains "$messages" "key =: choose-buffer -r" "reverse sort option passes -r to native chooser"
  assert_contains "$messages" "-O time" "reverse sort option keeps native chooser sorted by time"

  tmux_test "$sock" send-keys q >/dev/null 2>&1 || true
  stop_tmux "$sock"
  wait "$client_pid" >/dev/null 2>&1 || true
  trap - EXIT HUP INT TERM
  echo "ok - reverse sort option is respected"
}

